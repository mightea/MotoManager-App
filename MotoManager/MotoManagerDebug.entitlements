<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Debug-only entitlements, used when running on a device with a personal
	  (free) development team, which cannot sign the Associated Domains
	  capability. Consequence: passkey/WebAuthn login is unavailable in Debug
	  device builds — use password login there. Release keeps the full
	  entitlements in MotoManager.entitlements.
	-->
</dict>
</plist>
